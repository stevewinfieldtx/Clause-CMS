      "home": {
        "template": "<html><head></head><body>```html\n<style>\n  /* Base Scope */\n  .ninjio-mod { font-family: 'Inter', -apple-system, system-ui, sans-serif; color: #1d1d1f; line-height: 1.6; -webkit-font-smoothing: antialiased; background: #ffffff; }\n  .ninjio-mod * { box-sizing: border-box; margin: 0; padding: 0; }\n  \n  /* Brand Colors - Ninjio Specific */\n  .ninjio-mod .hero { \n    background: linear-gradient(135deg, #002D72 0%, #001A44 100%); \n    color: #fff; \n    padding: 96px 48px; \n    position: relative; \n    overflow: hidden; \n    background-image: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.55)), url('images/hero.jpg');\n    background-position: center;\n    background-size: cover;\n    background-repeat: no-repeat;\n  }\n  .ninjio-mod .hero-inner { position: relative; z-index: 1; max-width: 960px; }\n  .ninjio-mod .eyebrow { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 3px; color: #00B5E2; margin-bottom: 16px; }\n  \n  /* Typography Scale */\n  .ninjio-mod .hero h1 { font-size: 42px; font-weight: 900; line-height: 1.1; letter-spacing: -1px; margin-bottom: 18px; max-width: 700px; }\n  .ninjio-mod .hero p { font-size: 17px; line-height: 1.7; color: rgba(255,255,255,0.85); max-width: 580px; margin-bottom: 32px; }\n  .ninjio-mod .section-title { font-size: 32px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 12px; }\n  .ninjio-mod .section-sub { font-size: 16px; color: #6e6e73; max-width: 650px; margin-bottom: 32px; line-height: 1.7; }\n  \n  /* Buttons */\n  .ninjio-mod .btn { display: inline-block; padding: 14px 28px; border-radius: 8px; font-weight: 700; font-size: 14px; text-decoration: none; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; }\n  .ninjio-mod .btn-primary { background: #00B5E2; color: #fff; box-shadow: 0 2px 12px rgba(0,181,226,0.3); }\n  .ninjio-mod .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,181,226,0.4); }\n  .ninjio-mod .btn-ghost { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.3); margin-left: 12px; }\n  .ninjio-mod .btn-ghost:hover { background: rgba(255,255,255,0.08); }\n  \n  /* Structure & Layout */\n  .ninjio-mod .wrap { max-width: 960px; margin: 0 auto; padding: 0 48px; }\n  .ninjio-mod .section { padding: 64px 0; }\n  .ninjio-mod .section + .section { border-top: 1px solid #f0f0f0; }\n  .ninjio-mod .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }\n  .ninjio-mod .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }\n  .ninjio-mod .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }\n  \n  /* Responsive Breakpoint */\n  @media (max-width: 800px) { .ninjio-mod .grid-4, .ninjio-mod .grid-3, .ninjio-mod .grid-2 { grid-template-columns: 1fr; } }\n  \n  /* Dark Utilities & Elements */\n  .ninjio-mod .dark { background: #002D72; color: #fff; padding: 64px 0; position: relative; overflow: hidden; }\n  .ninjio-mod .dark .section-title { color: #fff; }\n  .ninjio-mod .dark .section-sub { color: rgba(255,255,255,0.6); }\n  .ninjio-mod .stat-card { text-align: center; padding: 24px 16px; background: rgba(255,255,255,0.06); border-radius: 12px; }\n  .ninjio-mod .stat-val { font-size: 36px; font-weight: 900; color: #00B5E2; letter-spacing: -1px; }\n  .ninjio-mod .stat-label { font-size: 12px; color: rgba(255,255,255,0.6); margin-top: 4px; }\n  \n  /* Cards & Glass Effects */\n  .ninjio-mod .card { background: #fff; border: 1px solid #e5e5e5; border-radius: 14px; padding: 28px; transition: all 0.3s ease; }\n  .ninjio-mod .card:hover { border-color: #00B5E2; box-shadow: 0 4px 20px rgba(0,0,0,0.08); transform: translateY(-3px); }\n  .ninjio-mod .card h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; }\n  .ninjio-mod .card p { font-size: 14px; color: #6e6e73; line-height: 1.65; }\n  .ninjio-mod .card-icon { width: 44px; height: 44px; border-radius: 12px; background: rgba(0,181,226,0.08); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }\n  .ninjio-mod .card-icon svg { width: 22px; height: 22px; }\n  .ninjio-mod .glass { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 24px; text-align: center; transition: all 0.3s ease; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }\n  .ninjio-mod .glass:hover { border-color: rgba(255,255,255,0.2); transform: translateY(-2px); }\n  .ninjio-mod .glass-label { font-size: 13px; font-weight: 600; opacity: 0.9; }\n  .ninjio-mod .glass-sub { font-size: 11px; opacity: 0.6; margin-top: 4px; }\n  .ninjio-mod .pill { display: inline-block; font-size: 12px; font-weight: 600; padding: 6px 16px; border-radius: 100px; background: rgba(0,181,226,0.07); color: #002D72; border: 1px solid rgba(0,181,226,0.15); margin: 4px; }\n  \n  /* Trust Items */\n  .ninjio-mod .trust-item { text-align: center; padding: 24px 16px; }\n  .ninjio-mod .trust-name { font-size: 22px; font-weight: 900; color: #002D72; }\n  .ninjio-mod .trust-since { font-size: 13px; color: #6e6e73; margin-top: 4px; }\n  .ninjio-mod .trust-detail { font-size: 11px; color: #999; margin-top: 2px; }\n  \n  /* Bottom CTA Block */\n  .ninjio-mod .cta-block { background: #002D72; color: #fff; padding: 72px 0; text-align: center; position: relative; overflow: hidden; }\n  .ninjio-mod .cta-block .wrap { position: relative; z-index: 1; }\n  .ninjio-mod .cta-block h2 { font-size: 32px; font-weight: 800; margin-bottom: 12px; }\n  .ninjio-mod .cta-block p { font-size: 16px; color: rgba(255,255,255,0.7); max-width: 480px; margin: 0 auto 28px; }\n</style>\n\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap\" rel=\"stylesheet\">\n\n<div class=\"ninjio-mod\">\n\n  <!-- 1. Hero -->\n  <div class=\"hero\">\n    <div class=\"hero-inner\">\n      <div class=\"eyebrow\">NINJIO Human Risk Management</div>\n      <h1 data-cms=\"cms-1\">Turn Your Worst Security Vulnerabilities into Your Strongest Defense</h1>\n      <p data-cms=\"cms-2\">Boring compliance videos don't stop hacker exploits. NINJIO delivers micro-learning episodes engineered by Hollywood storytellers to transform employee behavior, slash your Click-Through Rate, and neutralize human risk at the perimeter.</p>\n      <div>\n        <a class=\"btn btn-primary\" href=\"#partner-contact\" data-cta=\"hero_cta\" data-cms=\"cms-3\">Get a Behavioral Risk Assessment</a>\n        <a class=\"btn btn-ghost\" href=\"#episodes\" data-cms=\"cms-4\">Explore the Episodes</a>\n      </div>\n    </div>\n  </div>\n\n  <!-- 2. Trust Stats -->\n  <div class=\"dark\" style=\"padding:40px 0;\">\n    <div class=\"wrap\">\n      <div class=\"grid-4\">\n        <div class=\"stat-card\"><div class=\"stat-val\">99.9%</div><div class=\"stat-label\">Breach Reduction Metrics</div></div>\n        <div class=\"stat-card\"><div class=\"stat-val\">100M+</div><div class=\"stat-label\">Minutes Streamed</div></div>\n        <div class=\"stat-card\"><div class=\"stat-val\">3-4 Min</div><div class=\"stat-label\">Micro-Learning Focus</div></div>\n        <div class=\"stat-card\"><div class=\"stat-val\">0%</div><div class=\"stat-label\">Wasted Engagement Time</div></div>\n      </div>\n    </div>\n  </div>\n\n  <!-- 3. Threat Vector Section -->\n  <div class=\"section\">\n    <div class=\"wrap\">\n      <div class=\"eyebrow\" style=\"color:#002D72;\">Human Vulnerabilities</div>\n      <div class=\"section-title\">The Four Main Vectors. Defended.</div>\n      <div class=\"grid-2\" style=\"margin-top:28px;\" data-cms-collection=\"col1\">\n        <div class=\"card\" style=\"border-top:3px solid #00B5E2;\" data-cms-item=\"col1\">\n          <div class=\"card-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 2l8 4v6c0 5.5-3.8 10-8 11.5C7.8 22 4 17.5 4 12V6l8-4z\" stroke=\"#002D72\" stroke-width=\"1.5\"></path><path d=\"M9 12l2 2 4-4\" stroke=\"#00B5E2\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg></div>\n          <h3 data-cms=\"cms-5\">Spear Phishing</h3>\n          <p data-cms=\"cms-6\">Hackers impersonate executives using targeted psychological profiles. NINJIO trains employees to slow down, spot social engineering patterns, and systematically verify anomaly requests before clicking links.</p>\n        </div>\n        <div class=\"card\" style=\"border-top:3px solid #00B5E2;\" data-cms-item=\"col1\">\n          <div class=\"card-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"12\" r=\"9\" stroke=\"#002D72\" stroke-width=\"1.5\"></circle><path d=\"M12 8v4\" stroke=\"#00B5E2\" stroke-width=\"2\" stroke-linecap=\"round\"></path><circle cx=\"12\" cy=\"15\" r=\"1\" fill=\"#00B5E2\"></circle></svg></div>\n          <h3 data-cms=\"cms-7\">Credential Theft</h3>\n          <p data-cms=\"cms-8\">Fake login pages steal Microsoft 365, Google Workspace, and corporate identities. We map our educational content out to show exactly how attackers clone production portals to capture active MFA tokens.</p>\n        </div>\n        <div class=\"card\" style=\"border-top:3px solid #00B5E2;\" data-cms-item=\"col1\">\n          <div class=\"card-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><rect x=\"3\" y=\"7\" width=\"18\" height=\"12\" rx=\"2\" stroke=\"#002D72\" stroke-width=\"1.5\"></rect><circle cx=\"12\" cy=\"13\" r=\"3\" stroke=\"#00B5E2\" stroke-width=\"1.5\"></circle></svg></div>\n          <h3 data-cms=\"cms-9\">Social Engineering</h3>\n          <p data-cms=\"cms-10\">Exploiting urgency, fear, and institutional trust to manipulate users. Micro-episodes explain the mechanics of executive impersonation, urgent payroll redirects, and supplier invoice fraud.</p>\n        </div>\n        <div class=\"card\" style=\"border-top:3px solid #00B5E2;\" data-cms-item=\"col1\">\n          <div class=\"card-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"12\" r=\"9\" stroke=\"#002D72\" stroke-width=\"1.5\"></circle><path d=\"M8 12h8M12 8v8\" stroke=\"#00B5E2\" stroke-width=\"1.5\" stroke-linecap=\"round\"></path></svg></div>\n          <h3 data-cms=\"cms-11\">Malware &amp; Ransomware</h3>\n          <p data-cms=\"cms-12\">Unwitting execution of malicious macros and payload attachments hidden in files. Training stops the trigger finger, building an active organizational habit of vetting unexpected attachments.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- 4. Technology/Methodology Section -->\n  <div class=\"section\" id=\"episodes\">\n    <div class=\"wrap\">\n      <div class=\"eyebrow\" style=\"color:#002D72;\">Methodology</div>\n      <div class=\"section-title\">The NINJIO Difference</div>\n      <div class=\"section-sub\">Six intentional layers of behavioral psychology and advanced testing metrics engineered to fix the corporate security problem.</div>\n      <div class=\"grid-3\" data-cms-collection=\"col2\">\n        <div class=\"card\" data-cms-item=\"col2\">\n          <div class=\"card-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"8\" r=\"4\" stroke=\"#002D72\" stroke-width=\"1.5\"></circle><path d=\"M4 20c0-4 3-7 8-7s8 3 8 7\" stroke=\"#002D72\" stroke-width=\"1.5\"></path><path d=\"M16 6l2-2M18 6l-2-2\" stroke=\"#00B5E2\" stroke-width=\"1.5\" stroke-linecap=\"round\"></path></svg></div>\n          <h3 data-cms=\"cms-13\">Hollywood Writing</h3>\n          <p data-cms=\"cms-14\">Written by professional creators. High-stakes narratives make security concepts completely unforgettable to the end user.</p>\n        </div>\n        <div class=\"card\" data-cms-item=\"col2\">\n          <div class=\"card-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 3l8 5v6c0 5-3 9-8 10.5C7 23 4 19 4 14V8l8-5z\" stroke=\"#002D72\" stroke-width=\"1.5\"></path><path d=\"M9 12l2 2 4-4\" stroke=\"#00B5E2\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg></div>\n          <h3 data-cms=\"cms-15\">NINJIO PHISH</h3>\n          <p data-cms=\"cms-16\">Real-time simulation engine that feeds active threat intelligence into personalized employee test vectors.</p>\n        </div>\n        <div class=\"card\" data-cms-item=\"col2\">\n          <div class=\"card-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"12\" r=\"8\" stroke=\"#002D72\" stroke-width=\"1.5\"></circle><circle cx=\"12\" cy=\"12\" r=\"3\" stroke=\"#00B5E2\" stroke-width=\"1.5\"></circle></svg></div>\n          <h3 data-cms=\"cms-17\">NINJIO Sense</h3>\n          <p data-cms=\"cms-18\">Teaches core tactical focus rules so teams immediately recognize anomalous behavior regardless of technological medium.</p>\n        </div>\n        <div class=\"card\" data-cms-item=\"col2\">\n          <div class=\"card-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><rect x=\"5\" y=\"7\" width=\"14\" height=\"10\" rx=\"2\" stroke=\"#002D72\" stroke-width=\"1.5\"></rect><path d=\"M9 11h6M9 14h4\" stroke=\"#00B5E2\" stroke-width=\"1.5\" stroke-linecap=\"round\"></path></svg></div>\n          <h3 data-cms=\"cms-19\">Gamified Retention</h3>\n          <p data-cms=\"cms-20\">Compelling points, internal tracking leaderboards, and immediate rewards drive positive adoption without shaming users.</p>\n        </div>\n        <div class=\"card\" data-cms-item=\"col2\">\n          <div class=\"card-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><rect x=\"5\" y=\"5\" width=\"14\" height=\"14\" rx=\"3\" stroke=\"#002D72\" stroke-width=\"1.5\"></rect><rect x=\"8\" y=\"8\" width=\"8\" height=\"8\" rx=\"1\" stroke=\"#00B5E2\" stroke-width=\"1.5\"></rect></svg></div>\n          <h3 data-cms=\"cms-21\">Continuous Updates</h3>\n          <p data-cms=\"cms-22\">New anime-style threat scripts deployed monthly based on real corporate security breaches reported globally.</p>\n        </div>\n        <div class=\"card\" data-cms-item=\"col2\">\n          <div class=\"card-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 18V8h4l3 6 3-6h4v10\" stroke=\"#002D72\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path><line x1=\"2\" y1=\"21\" x2=\"22\" y2=\"21\" stroke=\"#00B5E2\" stroke-width=\"2\" stroke-linecap=\"round\"></line></svg></div>\n          <h3 data-cms=\"cms-23\">Advanced Analytics</h3>\n          <p data-cms=\"cms-24\">Track your precise human risk trends over time and target automated training remediations exactly where needed.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- 5. Performance/Differentiator Section -->\n  <div class=\"dark\">\n    <div class=\"wrap\">\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;\">\n        <div>\n          <div class=\"eyebrow\">Performance</div>\n          <div class=\"section-title\" style=\"margin-top:8px;\">Zero Productivity Drain. Maximum Security Retention.</div>\n          <p style=\"font-size:15px;color:rgba(255,255,255,0.75);line-height:1.7;margin-top:16px;\" data-cms=\"cms-25\">Traditional enterprise modules waste hours of operating focus. NINJIO targets lightning-fast, high-impact intervals that shift behavioral trends without exhausting employee time.</p>\n        </div>\n        <div class=\"grid-2\">\n          <div class=\"glass\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 28 28\" fill=\"none\" style=\"margin:0 auto 8px;display:block;\"><circle cx=\"14\" cy=\"14\" r=\"9\" stroke=\"rgba(255,255,255,0.2)\" stroke-width=\"2.5\"></circle><path d=\"M14 5a9 9 0 0 1 0 18\" stroke=\"#00B5E2\" stroke-width=\"2.5\" stroke-linecap=\"round\"></path></svg><div class=\"glass-label\">Micro-Learning</div></div>\n          <div class=\"glass\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 28 28\" fill=\"none\" style=\"margin:0 auto 8px;display:block;\"><rect x=\"4\" y=\"6\" width=\"20\" height=\"14\" rx=\"2\" stroke=\"rgba(255,255,255,0.4)\" stroke-width=\"2\"></rect><path d=\"M8 13h5M8 16h3\" stroke=\"#00B5E2\" stroke-width=\"1.5\" stroke-linecap=\"round\"></path></svg><div class=\"glass-label\">Ultra-Low Friction</div></div>\n          <div class=\"glass\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 28 28\" fill=\"none\" style=\"margin:0 auto 8px;display:block;\"><path d=\"M6 22V10l8-4 8 4v12\" stroke=\"rgba(255,255,255,0.4)\" stroke-width=\"2\"></path><rect x=\"11\" y=\"16\" width=\"6\" height=\"6\" stroke=\"#00B5E2\" stroke-width=\"1.5\"></rect></svg><div class=\"glass-label\">Rapid Deploy</div></div>\n          <div class=\"glass\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 28 28\" fill=\"none\" style=\"margin:0 auto 8px;display:block;\"><path d=\"M4 14h4l3-8 4 14 3-6h6\" stroke=\"#00B5E2\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg><div class=\"glass-label\">Zero Fatigue</div></div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- 6. Social Proof Section -->\n  <div class=\"section\">\n    <div class=\"wrap\">\n      <div class=\"eyebrow\" style=\"color:#002D72;\">Trusted</div>\n      <div class=\"section-title\">Built for Midmarket &amp; Enterprise Infrastructure</div>\n      <div class=\"grid-4\" style=\"margin-top:24px;\">\n        <div class=\"trust-item\"><div class=\"trust-name\">Logistics</div><div class=\"trust-since\">Since 2018</div><div class=\"trust-detail\">Reduced click rates by 84%</div></div>\n        <div class=\"trust-item\"><div class=\"trust-name\">Fintech</div><div class=\"trust-since\">Since 2020</div><div class=\"trust-detail\">12,000+ endpoints secured</div></div>\n        <div class=\"trust-item\"><div class=\"trust-name\">Healthcare</div><div class=\"trust-since\">Since 2017</div><div class=\"trust-detail\">Achieved perfect audit marks</div></div>\n        <div class=\"trust-item\"><div class=\"trust-name\">Legal Corp</div><div class=\"trust-since\">Since 2019</div><div class=\"trust-detail\">Active human threat defense</div></div>\n      </div>\n    </div>\n  </div>\n\n  <!-- 7. Awards/Recognition Section -->\n  <div class=\"dark\">\n    <div class=\"wrap\" style=\"text-align:center;\">\n      <div class=\"eyebrow\">Recognition</div>\n      <div class=\"section-title\" style=\"margin-top:8px;\">Industry Validated Performance</div>\n      <div class=\"grid-4\" style=\"margin-top:28px;\">\n        <div class=\"glass\"><div style=\"font-size:28px;margin-bottom:8px;\">🏆</div><div class=\"glass-label\">Gartner Peer Insights</div><div class=\"glass-sub\">Customer Choice Excellence</div></div>\n        <div class=\"glass\"><div style=\"font-size:28px;margin-bottom:8px;\">⭐</div><div class=\"glass-label\">G2 Leader</div><div class=\"glass-sub\">Top Rated Security Training</div></div>\n        <div class=\"glass\"><div style=\"font-size:28px;margin-bottom:8px;\">🏅</div><div class=\"glass-label\">Cybersecurity Excellence</div><div class=\"glass-sub\">Gold Winner Badge</div></div>\n        <div class=\"glass\"><div style=\"font-size:28px;margin-bottom:8px;\">🎖️</div><div class=\"glass-label\">Inc. 5000</div><div class=\"glass-sub\">Fastest Growing Security Platform</div></div>\n      </div>\n    </div>\n  </div>\n\n  <!-- 8 & 9. Platform & Compliance Badges -->\n  <div class=\"section\">\n    <div class=\"wrap\">\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:48px;\" data-cms-collection=\"col3\">\n        <div data-cms-item=\"col3\">\n          <div class=\"eyebrow\" style=\"color:#002D72;\">Platforms</div>\n          <div class=\"section-title\" style=\"font-size:24px;\">Seamless Stack Integration</div>\n          <p style=\"font-size:15px;color:#6e6e73;margin:12px 0 20px;line-height:1.7;\" data-cms=\"cms-26\">Unified automated management. Integrates deeply across major identity providers and active directory portals.</p>\n          <div><span class=\"pill\" data-cms=\"cms-27\">Microsoft 365</span><span class=\"pill\" data-cms=\"cms-28\">Google Workspace</span><span class=\"pill\" data-cms=\"cms-29\">Okta Identity</span><span class=\"pill\" data-cms=\"cms-30\">Active Directory</span><span class=\"pill\" data-cms=\"cms-31\">REST API</span><span class=\"pill\" data-cms=\"cms-32\">LMS SCORM</span></div>\n        </div>\n        <div data-cms-item=\"col3\">\n          <div class=\"eyebrow\" style=\"color:#002D72;\">Compliance</div>\n          <div class=\"section-title\" style=\"font-size:24px;\">Audit &amp; Regulation Certified</div>\n          <p style=\"font-size:15px;color:#6e6e73;margin:12px 0 20px;line-height:1.7;\" data-cms=\"cms-33\">Satisfy mandatory human training compliance frameworks immediately with auditable reporting metrics.</p>\n          <div><span class=\"pill\" data-cms=\"cms-34\">HIPAA</span><span class=\"pill\" data-cms=\"cms-35\">SOC 2 Type II</span><span class=\"pill\" data-cms=\"cms-36\">PCI DSS</span><span class=\"pill\" data-cms=\"cms-37\">NIST CSF</span><span class=\"pill\" data-cms=\"cms-38\">ISO 27001</span><span class=\"pill\" data-cms=\"cms-39\">CCPA / GDPR</span></div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- 10. Bottom CTA Block -->\n  <div class=\"cta-block\">\n    <div class=\"wrap\">\n      <h2 data-cms=\"cms-40\">Ready to Eliminate Your Human Security Vulnerabilities?</h2>\n      <p data-cms=\"cms-41\">Schedule an evaluation to test your workforce risk profile, lower your click rates, and protect your digital infrastructure assets.</p>\n      <div>\n        <a class=\"btn btn-primary\" href=\"#partner-contact\" data-cta=\"bottom_cta\" data-cms=\"cms-42\">Request a Free Human Risk Assessment</a>\n      </div>\n    </div>\n  </div>\n\n</div>\n\n```</body></html>",
