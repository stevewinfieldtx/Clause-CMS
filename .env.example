# Copy to .env (the server auto-reads process.env). The CMS works without a key
# using a local fallback planner, but a key unlocks full natural-language editing.
#
# AI editing via OpenRouter (default provider):
#   OPENROUTER_API_KEY=sk-or-...
#   OPENROUTER_MODEL_ID=anthropic/claude-sonnet-4.5   # any OpenRouter model slug
#
# Storage — required in production (Railway Mongo); leave unset to use local files:
#   MONGODB_URI=mongodb://...
#
# Owner dashboard master key (don't leave the default):
#   ADMIN_KEY=change-me
#
# Optional: change the port (default 4321; Railway sets PORT automatically)
#   PORT=4321
